# Firebase Central (para gestión de tenants)
NEXT_PUBLIC_CENTRAL_FIREBASE_API_KEY=
NEXT_PUBLIC_CENTRAL_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_CENTRAL_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_CENTRAL_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_CENTRAL_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_CENTRAL_FIREBASE_APP_ID=

# Dominio principal de la plataforma
NEXT_PUBLIC_PLATFORM_DOMAIN=createam.cloud

# Admin credentials (opcional, para proteger rutas admin)
ADMIN_SECRET_KEY=your-secret-key-here

# Firebase Admin SDK (server-side only)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Firebase tenant config usado por scripts de mantenimiento (opcional)
BELLASORPRESA_FIREBASE_API_KEY=
BELLASORPRESA_FIREBASE_AUTH_DOMAIN=
BELLASORPRESA_FIREBASE_PROJECT_ID=
BELLASORPRESA_FIREBASE_STORAGE_BUCKET=
BELLASORPRESA_FIREBASE_MESSAGING_SENDER_ID=
BELLASORPRESA_FIREBASE_APP_ID=
BELLASORPRESA_FIREBASE_MEASUREMENT_ID=

# Lista de correos autorizados para panel /admin (separados por coma)
NEXT_PUBLIC_PLATFORM_ADMIN_EMAILS=
PLATFORM_ADMIN_EMAILS=

# Max requests per minute por IP para rutas admin API
ADMIN_API_RATE_LIMIT=60

# Sesion segura httpOnly para admin
SESSION_COOKIE_NAME=createam_session
SESSION_COOKIE_MAX_AGE_DAYS=5
